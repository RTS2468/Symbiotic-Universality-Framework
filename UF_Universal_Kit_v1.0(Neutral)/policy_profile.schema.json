{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicyProfile",
  "type": "object",
  "required": [
    "name",
    "purpose_weights",
    "harm_caps",
    "consent_thresholds",
    "fairness_prior",
    "reversibility_weight",
    "red_lines",
    "evidence_gap_cap",
    "bias_cap",
    "opacity_cap"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "purpose_weights": {
      "type": "object",
      "required": [
        "self",
        "right",
        "help"
      ],
      "properties": {
        "self": {
          "type": "number"
        },
        "right": {
          "type": "number"
        },
        "help": {
          "type": "number"
        }
      }
    },
    "harm_caps": {
      "type": "object",
      "required": [
        "low",
        "med",
        "high"
      ],
      "properties": {
        "low": {
          "type": "number"
        },
        "med": {
          "type": "number"
        },
        "high": {
          "type": "number"
        }
      }
    },
    "consent_thresholds": {
      "type": "object",
      "required": [
        "sr_tau",
        "consent_tau"
      ],
      "properties": {
        "sr_tau": {
          "type": "number"
        },
        "consent_tau": {
          "type": "number"
        }
      }
    },
    "fairness_prior": {
      "type": "string",
      "enum": [
        "demographic_parity",
        "equal_opportunity",
        "individual_fairness",
        "custom"
      ]
    },
    "fairness_params": {
      "type": "object"
    },
    "reversibility_weight": {
      "type": "number"
    },
    "red_lines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_gap_cap": {
      "type": "number"
    },
    "bias_cap": {
      "type": "number"
    },
    "opacity_cap": {
      "type": "number"
    }
  }
}